#!/usr/bin/env bash
# gdsa — gds_agent launcher
#
# Usage:
#   gdsa claude    [path]   Run Claude Code CLI in path (default $PWD)
#   gdsa opencode  [path]   Run opencode, Ollama-wired with keep-alive
#   gdsa copilot   [path]   Run GitHub Copilot CLI in path
#   gdsa shell     [path]   Interactive bash in path, no harness, no creds
#   gdsa update             Replace this launcher with a fresh copy from main
#   gdsa help               Print this message
#
# Env overrides:
#   GDSA_IMAGE     Image tag to run (default: gds_agent:latest)
#   OLLAMA_HOST    Ollama endpoint URL (wins over provider-url.txt)

set -euo pipefail

IMAGE="${GDSA_IMAGE:-gds_agent:latest}"
CONTAINER_HOME="/home/jovyan"
WORKDIR="${CONTAINER_HOME}/work"
UPDATE_URL="https://raw.githubusercontent.com/darribas/gds_env/master/utils/gdsa"

# Resolve script dir portably (Linux + macOS). BSD readlink lacks -f.
_resolve_script_dir() {
  local source="${BASH_SOURCE[0]:-$0}" dir
  while [ -L "$source" ]; do
    dir="$(cd -P "$(dirname "$source")" && pwd)"
    source="$(readlink "$source")"
    [[ $source != /* ]] && source="$dir/$source"
  done
  cd -P "$(dirname "$source")" && pwd
}
SCRIPT_DIR="$(_resolve_script_dir)"

#--- Helpers ------------------------------------------------------------------

# Colors only when stdout is a TTY.
if [ -t 1 ]; then
  C_YELLOW=$'\033[33m'
  C_RED=$'\033[31m'
  C_DIM=$'\033[2m'
  C_RESET=$'\033[0m'
else
  C_YELLOW=''; C_RED=''; C_DIM=''; C_RESET=''
fi

_die()  { echo "${C_RED}gdsa: error:${C_RESET} $*" >&2; exit 1; }
_warn() { echo "${C_YELLOW}gdsa: heads up:${C_RESET} $*" >&2; }
_hint() { echo "${C_DIM}         $*${C_RESET}" >&2; }

_usage() {
  sed -n '2,15p' "$0" | sed 's/^# \{0,1\}//'
}

# Append `-v src:dst[:mode]` to MOUNTS only if src exists on host.
MOUNTS=()
_mount_if_exists() {
  local src="$1" dst="$2" mode="${3:-rw}"
  if [ -e "$src" ]; then
    MOUNTS+=(-v "${src}:${dst}:${mode}")
  fi
}

# Append `-e VAR` to ENVS only if VAR is set in the host env.
ENVS=()
_env_if_set() {
  local var="$1"
  if [ -n "${!var:-}" ]; then
    ENVS+=(-e "${var}")
  fi
}

# Mount the always-on set: gitconfig + ssh, read-only.
_mount_common() {
  _mount_if_exists "$HOME/.gitconfig" "${CONTAINER_HOME}/.gitconfig" ro
  _mount_if_exists "$HOME/.ssh"       "${CONTAINER_HOME}/.ssh"       ro
}

#--- Preflight ----------------------------------------------------------------
# Warn (don't block) about missing host-side files so the user knows what to
# fix without having to read this script. Each harness layers its own checks
# on top of the common ones.

_preflight_common() {
  if [ ! -f "$HOME/.gitconfig" ]; then
    _warn "no ~/.gitconfig found — commits inside the container will use a default identity."
    _hint "fix: git config --global user.name 'Your Name'"
    _hint "     git config --global user.email 'you@example.com'"
  fi
  if [ ! -d "$HOME/.ssh" ]; then
    _warn "no ~/.ssh/ found — git push over SSH won't work from the container."
    _hint "fix: ssh-keygen -t ed25519 -C 'you@example.com'"
  fi
}

_preflight_claude() {
  if [ ! -f "$HOME/.claude.json" ] && [ ! -d "$HOME/.claude" ]; then
    _warn "no Claude Code auth at ~/.claude.json or ~/.claude/ — first run will prompt you to log in."
    _hint "auth persists to ~/.claude.json + ~/.claude/ across container runs."
  fi
}

_preflight_opencode() {
  if [ ! -d "$HOME/.local/share/opencode" ]; then
    _warn "no opencode state at ~/.local/share/opencode/ — first run will initialize it."
    _hint "the keep-alive loop reads model state from this dir; it'll work once opencode writes there."
  fi
}

_preflight_copilot() {
  if [ ! -d "$HOME/.copilot" ]; then
    _warn "no Copilot CLI state at ~/.copilot/ — first run will prompt you to log in."
    _hint "auth and settings persist to ~/.copilot/ across container runs."
  fi
  if [ ! -d "$HOME/.config/gh" ]; then
    _warn "no ~/.config/gh/ found — gh CLI is unauthenticated; Copilot CLI uses it for GitHub access."
    _hint "fix: run 'gh auth login' in the environment launching 'gdsa copilot'; its ~/.config/gh/ will be mounted into the container."
  fi
}

# Resolve a hostname to an IP via whatever the host has handy.
# Tailscale MagicDNS-friendly.
_resolve_host() {
  local host="$1" ip=""
  if command -v getent >/dev/null 2>&1; then
    ip=$(getent hosts "$host" 2>/dev/null | awk '{print $1; exit}')
    [ -n "$ip" ] && { echo "$ip"; return 0; }
  fi
  if command -v dscacheutil >/dev/null 2>&1; then
    ip=$(dscacheutil -q host -a name "$host" 2>/dev/null \
         | awk '/^ip_address:/ {print $2; exit}')
    [ -n "$ip" ] && { echo "$ip"; return 0; }
  fi
  if command -v dig >/dev/null 2>&1; then
    ip=$(dig +short "$host" 2>/dev/null | awk '/^[0-9.]+$/ {print; exit}')
    [ -n "$ip" ] && { echo "$ip"; return 0; }
  fi
  if command -v host >/dev/null 2>&1; then
    ip=$(host "$host" 2>/dev/null | awk '/has address/ {print $NF; exit}')
    [ -n "$ip" ] && { echo "$ip"; return 0; }
  fi
  return 1
}

#--- Subcommands --------------------------------------------------------------

_cmd_claude() {
  local path="${1:-$PWD}"
  [ -d "$path" ] || _die "not a directory: $path"

  _preflight_common
  _preflight_claude

  _mount_common
  # Ensure host-side auth paths exist so mounts land on first run and auth persists.
  mkdir -p "$HOME/.claude"
  touch "$HOME/.claude.json"
  _mount_if_exists "$HOME/.claude"      "${CONTAINER_HOME}/.claude"      rw
  _mount_if_exists "$HOME/.claude.json" "${CONTAINER_HOME}/.claude.json" rw

  _env_if_set ANTHROPIC_API_KEY
  _env_if_set GITHUB_TOKEN
  _env_if_set GH_TOKEN

  exec docker run --rm -it \
    -v "${path}:${WORKDIR}" \
    -w "${WORKDIR}" \
    "${MOUNTS[@]}" \
    "${ENVS[@]}" \
    "$IMAGE" \
    claude --dangerously-skip-permissions
}

_cmd_copilot() {
  local path="${1:-$PWD}"
  [ -d "$path" ] || _die "not a directory: $path"

  _preflight_common
  _preflight_copilot

  _mount_common
  # Ensure host-side auth paths exist so mounts land on first run and auth persists.
  mkdir -p "$HOME/.copilot"
  mkdir -p "$HOME/.config/gh"
  _mount_if_exists "$HOME/.copilot"   "${CONTAINER_HOME}/.copilot"   rw
  _mount_if_exists "$HOME/.config/gh" "${CONTAINER_HOME}/.config/gh" rw

  _env_if_set GITHUB_TOKEN
  _env_if_set GH_TOKEN
  for v in $(env | awk -F= '/^COPILOT_/{print $1}'); do
    ENVS+=(-e "$v")
  done

  exec docker run --rm -it \
    -v "${path}:${WORKDIR}" \
    -w "${WORKDIR}" \
    "${MOUNTS[@]}" \
    "${ENVS[@]}" \
    "$IMAGE" \
    copilot --allow-all
}

_cmd_opencode() {
  local path="${1:-$PWD}"
  [ -d "$path" ] || _die "not a directory: $path"

  _preflight_common
  _preflight_opencode

  # Resolve Ollama endpoint: env wins, else provider-url.txt next to script.
  local ollama_host="${OLLAMA_HOST:-}"
  if [ -z "$ollama_host" ]; then
    local url_file="${SCRIPT_DIR}/provider-url.txt"
    if [ -f "$url_file" ]; then
      ollama_host=$(cat "$url_file")
    else
      _die "no OLLAMA_HOST set and ${url_file} not found. Set OLLAMA_HOST or drop a provider-url.txt next to gdsa."
    fi
  fi

  local hostname
  hostname=$(echo "$ollama_host" | sed -E 's|^https?://||' | cut -d':' -f1 | cut -d'/' -f1)
  local resolved_ip
  resolved_ip=$(_resolve_host "$hostname") || \
    _die "could not resolve $hostname — check DNS / Tailscale"
  echo "gdsa: resolved $hostname -> $resolved_ip"

  _mount_common
  _mount_if_exists "$HOME/.local/share/opencode" "${CONTAINER_HOME}/.local/share/opencode" rw
  _mount_if_exists "$HOME/.config/opencode"      "${CONTAINER_HOME}/.config/opencode"      rw

  ENVS+=(-e "OLLAMA_HOST=${ollama_host}")
  ENVS+=(-e "GLAMOUR_STYLE=dark")

  # Keep-alive: re-read the active model and ping Ollama every 4 min so the
  # model stays warm. Trap-cleaned on exit.
  local ollama_base
  ollama_base=$(echo "$ollama_host" | sed 's|/v1$||')
  local state_file="$HOME/.local/share/opencode/model.json"

  _keepalive() {
    while true; do
      sleep 240
      local model=""
      if [ -f "$state_file" ] && command -v jq >/dev/null 2>&1; then
        model=$(jq -r '.recent[0].modelID // empty' "$state_file" 2>/dev/null || true)
      fi
      if [ -n "$model" ]; then
        curl -s -o /dev/null -X POST "${ollama_base}/api/generate" \
          -H "Content-Type: application/json" \
          -d "{\"model\": \"${model}\", \"keep_alive\": \"5m\"}" || true
      fi
    done
  }
  _keepalive &
  local keepalive_pid=$!
  trap 'kill "$keepalive_pid" 2>/dev/null; wait "$keepalive_pid" 2>/dev/null || true' EXIT INT TERM

  docker run --rm -it \
    --add-host "${hostname}:${resolved_ip}" \
    -v "${path}:${WORKDIR}" \
    -w "${WORKDIR}" \
    "${MOUNTS[@]}" \
    "${ENVS[@]}" \
    "$IMAGE" \
    opencode
}

_cmd_shell() {
  local path="${1:-$PWD}"
  [ -d "$path" ] || _die "not a directory: $path"

  _preflight_common

  _mount_common

  exec docker run --rm -it \
    -v "${path}:${WORKDIR}" \
    -w "${WORKDIR}" \
    "${MOUNTS[@]}" \
    "$IMAGE" \
    bash
}

_cmd_update() {
  local target="${BASH_SOURCE[0]}"
  if [ ! -w "$target" ]; then
    _die "cannot write to $target (try: sudo gdsa update)"
  fi
  local tmp
  tmp=$(mktemp)
  curl -fsSL "$UPDATE_URL" -o "$tmp" || _die "download failed"
  chmod +x "$tmp"
  mv "$tmp" "$target"
  echo "gdsa: updated $target"
}

#--- Dispatch -----------------------------------------------------------------

case "${1:-help}" in
  claude)   shift; _cmd_claude   "$@" ;;
  opencode) shift; _cmd_opencode "$@" ;;
  copilot)  shift; _cmd_copilot  "$@" ;;
  shell)    shift; _cmd_shell    "$@" ;;
  update)   shift; _cmd_update   "$@" ;;
  help|-h|--help) _usage ;;
  *) _usage; exit 1 ;;
esac
